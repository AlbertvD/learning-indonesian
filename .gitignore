node_modules/
dist/
test-results/
.env.local
.env
.DS_Store

# Local audio source files — not committed, upload via seed scripts
content/lessons/
content/podcasts/

# Raw coursebook page images — not committed
content/raw/

# Intermediate extraction JSON — not committed
content/extracted/

# Git worktrees — isolated workspaces
.worktrees/

# Local tool config — not committed.
# EXCEPTIONS: .claude/agents/ and .claude/skills/ hold shared project assets — the
# dev agents (architect, data-architect, the linguist/content pipeline, …) and the
# project skills (lesson-pipeline, capability-stage, forge-id, …). They are tracked
# assets, not local config. Ignoring the whole .claude/ dir is why data-architect.md
# silently never landed on main despite being mandated by CLAUDE.md's dual-review
# rule — and would do the same to any new skill under .claude/skills/.
.claude/*
!.claude/agents/
!.claude/skills/
.playwright-mcp/

# Forge state — per-task ephemeral, not committed
.forge-state.json
.forge-check-pending

# TypeScript build artifacts
*.tsbuildinfo
*.d.ts
vite.config.js
/content/decision-3b-cleanup-backup-*.json

# Derived staging files — regenerated by capability-stage runner on every
# publish (scripts/lib/pipeline/capability-stage/runner.ts §1b). Hand-edits
# are overwritten; tracking them turns every re-publish PR into a diff full
# of regenerated noise. PR 1.5 (2026-05-22).
scripts/data/staging/lesson-*/content-units.ts
scripts/data/staging/lesson-*/capabilities.ts
scripts/data/staging/lesson-*/exercise-assets.ts
scripts/data/staging/lesson-*/lesson-page-blocks.ts
