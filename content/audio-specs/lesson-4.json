    { "stagingId": "nasi-putih", "text": "nasi putih", "language": "id", "type": "vocabulary_pronunciation", "priority": "high" },
    { "stagingId": "nasi-goreng", "text": "nasi goreng", "language": "id", "type": "vocabulary_pronunciation", "priority": "high" },
    { "stagingId": "nasi-kuning", "text": "nasi kuning", "language": "id", "type": "vocabulary_pronunciation", "priority": "high" },
    { "stagingId": "dialogue-1", "text": "Selamat siang, Mas. Kamar saya nomor berapa?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-2", "text": "Nomor 215, Bu. Di lantai 2.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-3", "text": "Paspor Ibu di mana? Saya harus isi formulir hotel.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-4", "text": "Ini paspor saya. Kunci saya di mana?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-5", "text": "Kunci yang kecil dan kuning ini kunci Ibu, silakan!", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-6", "text": "Kamar saya bagus. Kamar mandi ada di mana?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-7", "text": "Di sini, Bu. Handuk, sabun dan sikat gigi ada. Di situ bak air.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-8", "text": "Air di bak untuk mandi.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-9", "text": "Oke, terima kasih, ya Mas!", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-10", "text": "Mas, saya ingin makan. Apa makanan yang enak?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-11", "text": "Oo, apa Ibu suka ayam pedas, nasi kuning dan lauk?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-12", "text": "Eeh... suka, tetapi saya ingin makan sate kambing, gado-gado dan nasi putih.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-13", "text": "Tambah krupuk juga dan segelas air putih, ya Mas.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "grammar-yang-relative", "text": "Pisang yang terlalu tua tidak enak.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-nominal-1", "text": "Yang mahal bagus.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-nominal-2", "text": "Yang tidur banyak.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-emphasis", "text": "Rumah yang besar.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-unequal", "text": "Rumah besar yang kuning.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-equal", "text": "Rumah yang besar dan kuning.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-ada-yang", "text": "Ada yang dari negeri Belanda dan ada yang dari negeri Jerman.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-unequal-2", "text": "Sendok kecil yang bersih.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-yang-unequal-3", "text": "Kursi kecil yang putih.", "language": "id", "type": "grammar_example", "priority": "medium" }
  ]
}
