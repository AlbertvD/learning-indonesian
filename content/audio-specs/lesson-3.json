    { "stagingId": "udara", "text": "udara", "language": "id", "type": "vocabulary_pronunciation", "priority": "high" },
    { "stagingId": "dialogue-1", "text": "Pak! Di mana barang saya?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-2", "text": "Di sana, Bu.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-3", "text": "Di sebelah kiri atau kanan?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-4", "text": "O, barang saya berat sekali. Ada dua koper dan satu tas besar.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-5", "text": "Pak, pengangkut barang, di mana, ya Pak?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-6", "text": "Terima kasih banyak, Pak.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-7", "text": "Terima kasih kembali, Bu.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-8", "text": "Barang ini harus ke mana, Bu?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-9", "text": "Ke pabean saja, Pak.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-10", "text": "Ibu mau menginap di mana di kota?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-11", "text": "Belum tahu, Pak. Saya menginap dulu di rumah teman. Besok saya mau cari hotel.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-12", "text": "Nah, di sini pabean. Ini barang Ibu.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-13", "text": "Selamat siang, Bu, silakan buka koper.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-14", "text": "Minta tolong, Pak, koper saya berat sekali, penuh pakaian dan oleh-oleh untuk teman.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-15", "text": "Oleh-oleh apa, Bu?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-16", "text": "O, coklat dan keju. Di sini tidak ada 'kan?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-17", "text": "Ya, benar. Silakan, Bu. Saya sudah selesai.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-18", "text": "Pak, di mana ada taksi, ya Pak?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-19", "text": "Di depan, Bu, di sebelah pintu keluar.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-20", "text": "Sama-sama, Bu.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-closing", "text": "Ibu jalan keluar, lalu naik taksi ke Jakarta.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "grammar-ada-1", "text": "Di sana ada banyak mobil.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-ada-2", "text": "Ada keju? Ya, ada.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-ada-3", "text": "Ada berapa sepeda?", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-sekali-1", "text": "Hotel itu mahal sekali.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-sekali-2", "text": "Sepeda ini bagus sekali.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "grammar-dari-di-ke", "text": "Saya dari Bali. Sekarang tinggal di Solo. Besok saya pulang ke Jakarta.", "language": "id", "type": "grammar_example", "priority": "medium" },
    { "stagingId": "exercise-prompt-1", "text": "Saya ke Indonesia.", "language": "id", "type": "example_sentence", "priority": "low" },
