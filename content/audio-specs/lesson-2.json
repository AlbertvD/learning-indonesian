  "items": [
    { "stagingId": "dialogue-mulyono-1", "text": "Selamat siang, apa kabar? Bapak dari mana?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-barends-1", "text": "Saya dari negeri Belanda.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-mulyono-2", "text": "Nama Bapak siapa?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-barends-2", "text": "Nama saya Barends.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-mulyono-3", "text": "Dan ini Ibu Barends?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-barends-3", "text": "Ya, ini istri saya.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-mulyono-4", "text": "Bapak menginap di mana? Sudah dapat hotel?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-barends-4", "text": "Sudah. Sekarang mau ke hotel. Di mana bisa naik taksi?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-mulyono-5", "text": "Di sana. Bapak dan Ibu tinggal di mana?", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-ibu-barends", "text": "Saya dan suami saya tinggal di hotel Ramayana, Jalan Sinta nomor sebelas. Itu hotel bagus.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-barends-5", "text": "Nah, taksi sudah datang.", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-mulyono-6", "text": "Ooh, ya, saya pulang dulu. Sampai bertemu lagi!", "language": "id", "type": "dialogue_line", "priority": "high" },
    { "stagingId": "dialogue-barends-6", "text": "Sampai bertemu lagi, Pak.", "language": "id", "type": "dialogue_line", "priority": "high" },
