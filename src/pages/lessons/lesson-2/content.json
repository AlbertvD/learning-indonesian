  "sections": [
    {
      "order_index": 0,
      "content": {
        "type": "dialogue",
        "lines": [
          {
            "text": "Selamat siang, apa kabar? Bapak dari mana?",
            "speaker": "Bapak Mulyono",
            "translation": "Goedemiddag, hoe gaat het? Waar bent u vandaan?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/selamat-siang-apa-kabar-6f80df1b.mp3"
          },
          {
            "text": "Saya dari negeri Belanda.",
            "speaker": "Bapak Barends",
            "translation": "Ik kom uit Nederland.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/orus/saya-dari-negeri-belanda-ae13472a.mp3"
          },
          {
            "text": "Nama Bapak siapa?",
            "speaker": "Bapak Mulyono",
            "translation": "Wat is uw naam?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/nama-bapak-siapa-1e2fb4ce.mp3"
          },
          {
            "text": "Nama saya Barends.",
            "speaker": "Bapak Barends",
            "translation": "Mijn naam is Barends.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/orus/nama-saya-barends-9b13fc83.mp3"
          },
          {
            "text": "Dan ini Ibu Barends?",
            "speaker": "Bapak Mulyono",
            "translation": "En dit is mevrouw Barends?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/dan-ini-ibu-barends-baa85cca.mp3"
          },
          {
            "text": "Ya, ini istri saya.",
            "speaker": "Bapak Barends",
            "translation": "Ja, dit is mijn vrouw.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/orus/ya-ini-istri-saya-dda4b26f.mp3"
          },
          {
            "text": "Bapak menginap di mana? Sudah dapat hotel?",
            "speaker": "Bapak Mulyono",
            "translation": "Waar logeert u? Heeft u al een hotel gevonden?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/bapak-menginap-di-mana-4dbb211b.mp3"
          },
          {
            "text": "Sudah. Sekarang mau ke hotel. Di mana bisa naik taksi?",
            "speaker": "Bapak Barends",
            "translation": "Ja, dat klopt. Nu willen we naar het hotel. Waar kan ik een taxi nemen?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/orus/sudah-sekarang-mau-ke-9f6ad712.mp3"
          },
          {
            "text": "Di sana. Bapak dan Ibu tinggal di mana?",
            "speaker": "Bapak Mulyono",
            "translation": "Daar. Waar wonen u en mevrouw?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/di-sana-bapak-dan-82a9ba39.mp3"
          },
          {
            "text": "Saya dan suami saya tinggal di hotel Ramayana, Jalan Sinta nomor 11. Itu hotel bagus.",
            "speaker": "Ibu Barends",
            "translation": "Mijn man en ik wonen in het hotel Ramayana, Sintalaan nummer 11. Dat is een mooi hotel.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/saya-dan-suami-saya-d546637b.mp3"
          },
          {
            "text": "Nah, taksi sudah datang.",
            "speaker": "Bapak Barends",
            "translation": "Daar komt de taxi al aan.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/orus/nah-taksi-sudah-datang-b652ebf1.mp3"
          },
          {
            "text": "Ooh, ya, saya pulang dulu. Sampai bertemu lagi!",
            "speaker": "Bapak Mulyono",
            "translation": "O ja, ik ga naar huis. Tot ziens!",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/ooh-ya-saya-pulang-758328fe.mp3"
          },
          {
            "text": "Sampai bertemu lagi, Pak.",
            "speaker": "Bapak Barends",
            "translation": "Tot ziens!",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/orus/sampai-bertemu-lagi-pak-8f856d04.mp3"
          }
        ]
      }
    },
