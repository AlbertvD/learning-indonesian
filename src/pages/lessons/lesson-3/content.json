  "sections": [
    {
      "order_index": 0,
      "content": {
        "type": "dialogue",
        "lines": [
          {
            "text": "Pak! Di mana barang saya?",
            "speaker": "Ibu Yulia",
            "translation": "Meneer! Waar zijn mijn spullen?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/pak-di-mana-barang-2ba7b95f.mp3"
          },
          {
            "text": "Di sana, Bu.",
            "speaker": "Pekerja",
            "translation": "Daar, mevrouw.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/achird/di-sana-bu-8f69ebcb.mp3"
          },
          {
            "text": "Di sebelah kiri atau kanan?",
            "speaker": "Ibu Yulia",
            "translation": "Links of rechts?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/di-sebelah-kiri-atau-200706c0.mp3"
          },
          {
            "text": "Kanan, Bu.",
            "speaker": "Pekerja",
            "translation": "Rechts, mevrouw.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/achird/kanan-bu-16cf81b7.mp3"
          },
          {
            "text": "O, barang saya berat sekali. Ada dua koper dan satu tas besar. Pak, pengangkut barang, di mana, ya Pak?",
            "speaker": "Ibu Yulia",
            "translation": "O, mijn bagage is erg zwaar. Ik heb twee koffers en een grote tas. Meneer, transporteur, waar bent u?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/o-barang-saya-berat-3a3c368a.mp3"
          },
          {
            "text": "Di sana, Bu.",
            "speaker": "Pekerja",
            "translation": "Daar, mevrouw.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/achird/di-sana-bu-8f69ebcb.mp3"
          },
          {
            "text": "Terima kasih banyak, Pak.",
            "speaker": "Ibu Yulia",
            "translation": "Dank je wel, meneer.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/terima-kasih-banyak-pak-1e1fe606.mp3"
          },
          {
            "text": "Terima kasih kembali, Bu.",
            "speaker": "Pekerja",
            "translation": "Graag gedaan, mevrouw.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/achird/terima-kasih-kembali-bu-e46d2317.mp3"
          },
          {
            "text": "Barang ini harus ke mana, Bu?",
            "speaker": "Pengangkut",
            "translation": "Waar moet dit naar toe, mevrouw?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/gacrux/barang-ini-harus-ke-1ef3903f.mp3"
          },
          {
            "text": "Ke pabean saja, Pak.",
            "speaker": "Ibu Yulia",
            "translation": "Alleen naar de douane, meneer.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/ke-pabean-saja-pak-41c1f12a.mp3"
          },
          {
            "text": "Ibu mau menginap di mana di kota?",
            "speaker": "Pengangkut",
            "translation": "Waar gaat u in de stad logeren?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/gacrux/ibu-mau-menginap-di-58bcc6b5.mp3"
          },
          {
            "text": "Belum tahu, Pak. Saya menginap dulu di rumah teman. Besok saya mau cari hotel.",
            "speaker": "Ibu Yulia",
            "translation": "Weet ik nog niet, meneer. Ik logeer eerst bij een vriendin. Morgen zoek ik een hotel.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/belum-tahu-pak-saya-6c68e8e9.mp3"
          },
          {
            "text": "Nah, di sini pabean. Ini barang Ibu.",
            "speaker": "Pengangkut",
            "translation": "Hier is de douane. Dit zijn uw spullen.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/gacrux/nah-di-sini-pabean-44dcb60b.mp3"
          },
          {
            "text": "Terima kasih, Pak.",
            "speaker": "Ibu Yulia",
            "translation": "Dank je wel, meneer.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/terima-kasih-pak-5ca3f24f.mp3"
          },
          {
            "text": "Selamat siang, Bu, silakan buka koper.",
            "speaker": "Pabean",
            "translation": "Goedemiddag, mevrouw, wilt u alstublieft uw koffer openmaken?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/selamat-siang-bu-silakan-1a0014b9.mp3"
          },
          {
            "text": "Minta tolong, Pak, koper saya berat sekali, penuh pakaian dan oleh-oleh untuk teman.",
            "speaker": "Ibu Yulia",
            "translation": "Kunt u me helpen, meneer? Mijn koffer is erg zwaar, vol met kleding en souvenirs voor vrienden.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/minta-tolong-pak-koper-29782f18.mp3"
          },
          {
            "text": "Oleh-oleh apa, Bu?",
            "speaker": "Pabean",
            "translation": "Wat voor souvenirs, mevrouw?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/oleholeh-apa-bu-62cb7c7e.mp3"
          },
          {
            "text": "O, coklat dan keju. Di sini tidak ada 'kan?",
            "speaker": "Ibu Yulia",
            "translation": "O, chocolade en kaas. Die hebben jullie hier niet, toch?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/o-coklat-dan-keju-6c985d08.mp3"
          },
          {
            "text": "Ya, benar. Silakan, Bu. Saya sudah selesai.",
            "speaker": "Pabean",
            "translation": "Dat klopt. Prima, mevrouw. Ik ben klaar.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/ya-benar-silakan-bu-2290f92f.mp3"
          },
          {
            "text": "Pak, di mana ada taksi, ya Pak?",
            "speaker": "Ibu Yulia",
            "translation": "Meneer, waar kan ik hier een taxi vinden?",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/pak-di-mana-ada-cbcd7966.mp3"
          },
          {
            "text": "Di depan, Bu, di sebelah pintu keluar.",
            "speaker": "Pabean",
            "translation": "Buiten, mevrouw, bij de uitgang.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/di-depan-bu-di-21d9f904.mp3"
          },
          {
            "text": "Terima kasih, Pak.",
            "speaker": "Ibu Yulia",
            "translation": "Dank je wel, meneer.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/despina/terima-kasih-pak-5ca3f24f.mp3"
          },
          {
            "text": "Sama-sama, Bu.",
            "speaker": "Pabean",
            "translation": "Graag gedaan, mevrouw.",
            "audioUrl": "https://api.supabase.duin.home/storage/v1/object/public/indonesian-tts/tts/algenib/samasama-bu-dab28c83.mp3"
          }
        ],
        "closing": "Ibu jalan keluar, lalu naik taksi ke Jakarta."
      }
    },
